\@writefile{toc}{\contentsline {subsection}{\numberline {\mbox  {V-D}}Generalization: TriviaQA and BEIR}{5}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces End-to-end answer quality: NELA vs.\ all baselines ($n{=}500$). NELA achieves +55.2~pp EM over no-RAG, +10.8~pp over LlamaIndex, and +38.8~pp over ChromaDB.}}{6}{}\protected@file@percent }
\newlabel{fig:e2e}{{4}{6}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces E2E latency CDF for NELA (p50=84.75~ms, p95=98.5~ms, p99=105~ms). NELA is 2--3$\times $ faster than Python baselines at all percentiles.}}{6}{}\protected@file@percent }
\newlabel{fig:e2e_latency}{{5}{6}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Cross-dataset generalization: EM and Token~F1 on SQuAD~1.1 and TriviaQA-RC for NELA RAG vs.\ No-RAG. 95\% bootstrap CIs shown on NELA bars. NELA delivers +39.8~pp EM gain on TriviaQA despite the 10$\times $ larger corpus.}}{6}{}\protected@file@percent }
\newlabel{fig:trivia}{{6}{6}{}{}{}}
\@writefile{lot}{\contentsline {table}{\numberline {IV}{\ignorespaces BEIR Zero-Shot Retrieval: NDCG@10 / MAP / Recall@100 / MRR}}{6}{}\protected@file@percent }

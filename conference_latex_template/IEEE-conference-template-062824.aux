\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Retrieval metrics (Recall@5, Recall@10, MRR) for all four retrieval configurations on SQuAD~1.1. Hybrid RRF achieves the highest scores on all three metrics.}}{5}{}\protected@file@percent }

\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Query latency breakdown for the Hybrid+Expand configuration. IVF ANN (2.35~ms) accounts for 54\% of the 4.34~ms retrieval total; LLM generation dominates the full E2E pipeline (p50=84.75~ms, p95=98.5~ms).}}{5}{}\protected@file@percent }
\newlabel{fig:latency}{{3}{5}{}{}{}}

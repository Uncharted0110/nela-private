\@writefile{toc}{\contentsline {subsubsection}{\numberline {\mbox  {V-E}2}RRF Fusion Constant}{6}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces BEIR zero-shot retrieval: NDCG@10 (left) and Recall@100 (right) for BM25-only, Vector-only, and Hybrid across SciFact, NFCorpus, and FiQA-2018. Hybrid leads on SciFact and NFCorpus; dense retrieval is superior on the paraphrastic FiQA queries.}}{7}{}\protected@file@percent }
\newlabel{fig:beir}{{7}{7}{}{}{}}
\@writefile{lot}{\contentsline {table}{\numberline {V}{\ignorespaces Chunking Ablation: Hybrid Recall@5, MRR, Latency (ms)}}{7}{}\protected@file@percent }
\newlabel{tab:ablate_chunk}{{V}{7}{}{}{}}
\@writefile{lot}{\contentsline {table}{\numberline {VI}{\ignorespaces RRF Constant Ablation: Hybrid Recall@5 and MRR}}{7}{}\protected@file@percent }
\newlabel{tab:ablate_rrf}{{VI}{7}{}{}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {\mbox  {V-E}3}Embedding Model Quantization}{7}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Chunking strategy ablation: Recall@5 heatmap (left) across 4 chunk sizes $\times $ 3 overlaps, and MRR vs.\ overlap for each chunk size (right). Recall@5 varies only 0.022 across all 12 configurations, demonstrating NELA's robustness to chunking choice. Default 1{,}024/128 (dashed line) is Pareto-optimal.}}{7}{}\protected@file@percent }
\newlabel{fig:chunking}{{8}{7}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces RRF fusion constant ablation: Recall@5 (left axis) and MRR (right axis) as $k$ varies from 10 to 200. Recall@5 fluctuates by only 0.4~pp, confirming near-complete insensitivity. Default $k{=}60$ (dotted line) achieves the peak Recall@5.}}{7}{}\protected@file@percent }
\newlabel{fig:rrf_k}{{9}{7}{}{}{}}
\@writefile{lot}{\contentsline {table}{\numberline {VII}{\ignorespaces Embedding Model Quantization Ablation}}{7}{}\protected@file@percent }
\newlabel{tab:ablate_quant}{{VII}{7}{}{}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {\mbox  {V-F}}RAPTOR Hierarchical Retrieval}{7}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Embedding model quantization ablation: quality metrics (left) and average embedding latency (right) for BGE-base-Q8 vs.\ BGE-small-Q8. BGE-base-Q8 achieves superior recall and MRR at \emph  {lower} embedding latency, validating NELA's default choice.}}{8}{}\protected@file@percent }
\newlabel{fig:quant}{{10}{8}{}{}{}}
\@writefile{lot}{\contentsline {table}{\numberline {VIII}{\ignorespaces RAPTOR Gating Strategies vs.\ Flat Hybrid Retrieval}}{8}{}\protected@file@percent }
\newlabel{tab:raptor}{{VIII}{8}{}{}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {\mbox  {V-G}}Scale Degradation}{8}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces RAPTOR gating strategies vs.\ flat retrieval on SQuAD~1.1 (left) and TriviaQA-RC (right) at Recall@5. Flat hybrid consistently outperforms all RAPTOR variants on both corpora; RAPTOR expand-all is the best RAPTOR variant but remains 32~pp below flat hybrid on SQuAD. Results motivate corpus-adaptive gating calibration.}}{8}{}\protected@file@percent }
\newlabel{fig:raptor}{{11}{8}{}{}{}}
